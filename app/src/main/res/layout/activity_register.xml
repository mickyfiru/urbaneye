<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_app_gradient" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="28dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Únete a UrbanEye" android:textColor="@color/urban_text" android:textSize="30sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Reportes anónimos, ubicación automática y alertas cercanas en un diseño premium." android:textColor="@color/urban_text_muted" android:textSize="15sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:background="@drawable/bg_card" android:elevation="18dp" android:orientation="vertical">
            <EditText android:id="@+id/usernameInput" android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_input" android:hint="Nombre de usuario" android:textColor="@color/urban_text" android:textColorHint="@color/urban_text_muted" />
            <EditText android:id="@+id/emailInput" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_input" android:hint="Email" android:inputType="textEmailAddress" android:textColor="@color/urban_text" android:textColorHint="@color/urban_text_muted" />
            <EditText android:id="@+id/passwordInput" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_input" android:hint="Contraseña" android:inputType="textPassword" android:textColor="@color/urban_text" android:textColorHint="@color/urban_text_muted" />
            <Button android:id="@+id/createAccountButton" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="18dp" android:background="@drawable/bg_primary_button" android:text="Crear mi cuenta" android:textAllCaps="false" android:textColor="@color/urban_text" android:textStyle="bold" />
            <ProgressBar android:id="@+id/progress" android:layout_width="32dp" android:layout_height="32dp" android:layout_gravity="center_horizontal" android:layout_marginTop="12dp" android:indeterminateTint="@color/urban_primary_soft" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
